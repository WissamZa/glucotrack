# GlucoTrack Environment Variables

# SQLite database path (relative to project root for dev, absolute for prod)
DATABASE_URL=file:./db/custom.db

# Google OAuth Client ID (optional — needed only for Google Drive sync).
# Create at https://console.cloud.google.com/apis/credentials
# 1. Enable "Google Drive API"
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add your app's origin to "Authorized JavaScript origins"
#
# Each end-user signs in with THEIR OWN Google account.
# This Client ID only identifies the app to Google — it does NOT identify users.
GOOGLE_CLIENT_ID=""
