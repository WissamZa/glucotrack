// Prisma schema for GlucoTrack app — SQLite local storage

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== Readings =====
model Reading {
  id        String   @id @default(cuid())
  value     Int
  type      String   // fasting | before_meal | after_meal | before_sleep | after_exercise | other
  timestamp DateTime
  notes     String?
  carbs     Int?
  insulin   Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([timestamp])
  @@index([type])
}

// ===== Reminders =====
model Reminder {
  id        String   @id @default(cuid())
  time      String   // "08:00"
  label     String
  type      String   // same enum as Reading.type
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== Settings (singleton — id always = 1) =====
model Settings {
  id           Int     @id @default(1)
  language     String  @default("ar")   // ar | en
  theme        String  @default("classic") // classic | modern | elder
  diabetesType String  @default("type2") // type1 | type2 | gestational
  targetMin    Int     @default(80)
  targetMax    Int     @default(180)
  unit         String  @default("mg_dL") // mg_dL | mmol_L
  userName     String  @default("")
  onboarded    Boolean @default(false)
}

// ===== Sync State (singleton — id always = 1) =====
// Tracks Google Drive connection + last sync info.
// Access/refresh tokens are stored locally only (encrypted at app layer).
model SyncState {
  id             Int       @id @default(1)
  provider       String    @default("")     // "" | "google_drive"
  connected      Boolean   @default(false)
  accountEmail   String?
  accessToken    String?
  refreshToken   String?
  expiresAt      DateTime?
  lastSyncAt     DateTime?
  lastSyncStatus String?   // success | failed | in_progress
  lastSyncError  String?
  driveFileId    String?   // ID of the backup file in Drive
  updatedAt      DateTime  @updatedAt
}
